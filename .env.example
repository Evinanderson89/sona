# Copy to apps/api/.env and fill in.
ANTHROPIC_API_KEY=sk-ant-...
PORT=8787
# Hard cap on cumulative Claude spend (USD). The API refuses new calls past this.
# Persisted to apps/api/.usage.json so it survives restarts.
BUDGET_CAP_USD=25
# Mobile app reads this to know where the API lives. For local dev on a
# physical phone, set this to your Mac's LAN IP (e.g. http://192.168.1.42:8787).
EXPO_PUBLIC_API_URL=http://localhost:8787
