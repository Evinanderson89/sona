{
  "name": "@sona/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node scripts/link-deps.js",
    "link-deps": "node scripts/link-deps.js",
    "start": "node scripts/link-deps.js && expo start",
    "android": "node scripts/link-deps.js && expo start --android",
    "ios": "node scripts/link-deps.js && expo start --ios",
    "web": "node scripts/link-deps.js && expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sona/shared": "*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~51.0.39",
    "expo-av": "~14.0.7",
    "expo-constants": "~16.0.2",
    "expo-linking": "~6.3.1",
    "expo-router": "~3.5.24",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-web": "~0.19.10",
    "react-native-webview": "13.8.6",
    "pitchfinder": "^2.3.2"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3"
  }
}
